PORT=3000
NODE_ENV=development

MCP_SERVER_SECRET=replace_with_random_secret_used_by_retell_header

HUBSPOT_ACCESS_TOKEN=replace_with_hubspot_private_app_retell_connection_token
HUBSPOT_API_BASE=https://api.hubapi.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key_not_publishable_key

DEFAULT_TIMEZONE=Europe/Madrid

HUBSPOT_IN_PERSON_MEETING_URL=https://meetings-eu1.hubspot.com/info-madrid?uuid=your-uuid
HUBSPOT_VIRTUAL_MEETING_URL=https://meetings-eu1.hubspot.com/info-madrid/virtual-tour-booking-carabanchel?uuid=your-uuid

HUBSPOT_IN_PERSON_SLUG=info-madrid
HUBSPOT_VIRTUAL_SLUG=info-madrid/virtual-tour-booking-carabanchel

DEFAULT_TOUR_DURATION_MINUTES=30

# Retell API (required when SYNC_ENABLED=true)
RETELL_API_KEY=replace_with_retell_api_key
RETELL_API_BASE=https://api.retellai.com

# HubSpot deal filter: only sync deals where this boolean property is true
HUBSPOT_AI_CALL_ATTEMPTED_PROPERTY=ai_call_attempted
HUBSPOT_RETELL_CALL_ID_PROPERTIES=retell_call_id,retell_session_id,ai_retell_call_id
HUBSPOT_DEAL_UNIT_TYPE_PROPERTY=unit_type__carabanchel_
HUBSPOT_DEAL_CONTRACT_START_PROPERTY=desired_check_in_date
HUBSPOT_DEAL_CONTRACT_END_PROPERTY=desired_check_out_date
HUBSPOT_DEAL_PIPELINE_LABEL=Hubs B2C - Carabanchel
RETELL_SYNC_CALL_STATUSES=ended,not_connected
RETELL_SYNC_FAILED_DISCONNECTION_REASONS=dial_no_answer,dial_busy,telephony_provider_permission_denied,dial_failed

# In-process incremental sync (Option B)
SYNC_ENABLED=true
SYNC_INTERVAL_MS=3600000
SYNC_INITIAL_DELAY_MS=60000
